{
  "schemaVersion": 1,
  "id": "healthindicators",
  "version": "${version}",

  "name": "Health Indicators: Next",
  "description": "A lovingly hand-migrated 26.2 port of Health Indicators... finished exactly one day before the original mod rose from its 6-month grave and shipped its own 26.2 build. So now there are two. This is the one nobody asked for. Shows a floating health bar (or number) above Players and Mobs, with 100% extra emotional damage to the developer.",
  "authors": ["AdyTech99"],
  "contributors": [
    "Translation key (ru_ru): Alexander317"
  ],

  "contact": {
    "homepage": "https://modrinth.com/mod/health-indicators",
    "sources": "https://github.com/AdyTech99/HealthIndicators",
    "issues": "https://github.com/AdyTech99/HealthIndicators/issues"
  },

  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.com/invite/4eWX2duHfJ"
      },
      "update_checker": true
    }
  },

  "license": "LGPL v3",
  "icon": "assets/healthindicators/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      "io.github.adytech99.healthindicators.fabric.HealthIndicatorsFabric"
    ],
    "modmenu" : ["io.github.adytech99.healthindicators.fabric.config.ModMenuAPIImpl"]
  },
  "accessWidener": "healthindicators.accesswidener",
  "mixins": [
    "healthindicators.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.17.2",
    "fabric-api": "*",
    "minecraft": "~26.2-",
    "architectury": ">=19.0.1",
    "yet_another_config_lib_v3": "*",
    "java": ">=21"
  }
}